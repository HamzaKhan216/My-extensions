{
  "manifest_version": 3,
  "name": "Omni-Copilot AI",
  "version": "1.0.3",
  "description": "Your universal AI assistant that reads webpages.",
  "permissions": ["sidePanel", "activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_title": "Click to open Omni-Copilot",
    "default_icon": "icon.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "Open Omni-Copilot"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}